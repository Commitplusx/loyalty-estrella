# ============================================
# VARIABLES DE ENTORNO - ESTRELLA DELIVERY
# ============================================
# Copia este archivo a .env y completa tus credenciales

# Supabase Configuration
# Obtén estas credenciales de tu proyecto de Supabase:
# https://app.supabase.com/project/_/settings/api
VITE_SUPABASE_URL=https://tu-proyecto.supabase.co
VITE_SUPABASE_ANON_KEY=tu-anon-key-aqui

# NOTA: No compartas nunca tu SERVICE_ROLE_KEY
# Esa clave es solo para el backend/admin
