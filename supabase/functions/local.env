# ══════════════════════════════════════════════════════════════════════════════
# local.env — CONFIGURACIÓN DE PRUEBAS LOCALES (MODO MOCK)
# ══════════════════════════════════════════════════════════════════════════════

# MOCK_AI: Si es 'true', el bot responderá instantáneamente con un JSON estático 
# sin llamar a DeepSeek. Imprescindible para pruebas de estrés gratuitas.
DEBUG_MOCK_AI=true

# Credenciales locales de Supabase (se llenan automáticamente por la CLI)
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_SERVICE_ROLE_KEY=eyLocalServiceRoleKey...

# Secretos de WhatsApp (Vacío para desactivar validación de firma en tests locales)
WHATSAPP_APP_SECRET=
ADMIN_PHONES=5219631539156
DEEPSEEK_API_KEY=sk-mock-key-123
WA_PHONE_ID=12345
WA_TOKEN=fake-token-456
CHATWOOT_ACCOUNT_ID=1
CHATWOOT_TOKEN=fake-token-789
